<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_page"
    android:fitsSystemWindows="true"
    tools:context=".WidgetActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="48dp"
        android:paddingBottom="32dp">

        <!-- ── Title ────────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:text="@string/title_widget_demo"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <!-- ── Status ───────────────────────────────────────────────────── -->
        <TextView
            android:id="@+id/resultText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:minHeight="40dp"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <!-- ── Section: Payment Element ────────────────────────────────── -->
        <TextView
            style="@style/HsSectionLabel"
            android:text="@string/section_payment_element" />

        <io.hyperswitch.view.PaymentElement
            android:id="@+id/paymentElement"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Reload and Update Intent side by side -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/reloadButton2"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/rounded_button_outline"
                android:text="@string/btn_reload_secret"
                android:textAllCaps="false"
                android:textColor="@color/hs_blue_outline"
                android:textSize="14sp" />

            <Button
                android:id="@+id/updateIntent"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/rounded_button_outline"
                android:text="@string/btn_update_intent"
                android:textAllCaps="false"
                android:textColor="@color/hs_blue_outline"
                android:textSize="14sp" />

        </LinearLayout>

        <Button
            style="@style/HsButtonPrimary"
            android:id="@+id/confirmButton2"
            android:layout_marginTop="8dp"
            android:enabled="false"
            android:text="@string/btn_confirm_card" />

        <!-- ── Divider ──────────────────────────────────────────────────── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="28dp"
            android:background="@color/divider" />

        <!-- ── Section: CVC Widget ─────────────────────────────────────── -->
        <TextView
            style="@style/HsSectionLabel"
            android:text="@string/section_cvc_widget" />

        <io.hyperswitch.view.CVCWidget
            android:id="@+id/cvcWidget"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp" />

        <!-- ── Divider ──────────────────────────────────────────────────── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="28dp"
            android:background="@color/divider" />

        <!-- ── Section: Saved Methods ──────────────────────────────────── -->
        <TextView
            style="@style/HsSectionLabel"
            android:text="@string/section_saved_methods" />

        <!-- Row: Inspect saved methods -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/getLastUsedButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/rounded_button_outline"
                android:enabled="false"
                android:text="@string/btn_get_last_used"
                android:textAllCaps="false"
                android:textColor="@color/hs_blue_outline"
                android:textSize="13sp" />

            <Button
                android:id="@+id/getDefaultSavedMethodButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/rounded_button_outline"
                android:enabled="false"
                android:text="@string/btn_get_default"
                android:textAllCaps="false"
                android:textColor="@color/hs_blue_outline"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- Row: Confirm with CVC -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/confirmLastUsedWithCVCButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/rounded_button"
                android:enabled="false"
                android:text="@string/btn_confirm_last_used_cvc"
                android:textAllCaps="false"
                android:textColor="@color/text_on_brand"
                android:textSize="13sp" />

            <Button
                android:id="@+id/confirmDefaultWithCVCButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/rounded_button"
                android:enabled="false"
                android:text="@string/btn_confirm_default_cvc"
                android:textAllCaps="false"
                android:textColor="@color/text_on_brand"
                android:textSize="13sp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>

<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F8FA"
    android:fitsSystemWindows="true"
    tools:context=".WidgetActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="?attr/actionBarSize"
        android:paddingBottom="32dp">

        <!-- Status / Result -->
        <TextView
            android:id="@+id/resultText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:textSize="16sp"
            android:textColor="#333333" />

        <Button
            android:id="@+id/updateIntent"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/rounded_button_outline"
            android:text="Update Intent"
            android:textAllCaps="false"
            android:textColor="#0070F3"
            android:textSize="15sp" />

        <!-- ── Section: Payment Element ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:text="PAYMENT ELEMENT"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:textColor="#888888" />

        <io.hyperswitch.view.PaymentElement
            android:id="@+id/paymentElement"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp" />

        <Button
            android:id="@+id/reloadButton2"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/rounded_button_outline"
            android:text="Reload Client Secret"
            android:textAllCaps="false"
            android:textColor="#0070F3"
            android:textSize="15sp" />

        <Button
            android:id="@+id/confirmButton2"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/rounded_button"
            android:text="Confirm Card"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="15sp" />

        <!-- ── Divider ── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="28dp"
            android:background="#E2E8F0" />

        <!-- ── Section: CVC Widget ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp"
            android:text="CVC WIDGET"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:textColor="#888888" />

        <io.hyperswitch.view.CVCWidget
            android:id="@+id/cvcWidget"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp" />

        <!-- ── Section: Saved Methods ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="8dp"
            android:text="SAVED METHODS"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:textColor="#888888" />

        <!-- Row 1: Get methods -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/getLastUsedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/rounded_button_outline"
                android:text="Get Last Used"
                android:textAllCaps="false"
                android:textColor="#0070F3"
                android:textSize="13sp" />

            <Button
                android:id="@+id/getDefaultSavedMethodButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/rounded_button_outline"
                android:text="Get Default Saved"
                android:textAllCaps="false"
                android:textColor="#0070F3"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- Row 2: Confirm with CVC -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/confirmDefaultWithCVCButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/rounded_button"
                android:text="Confirm Default + CVC"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <Button
                android:id="@+id/confirmLastUsedWithCVCButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/rounded_button"
                android:text="Confirm Last Used + CVC"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
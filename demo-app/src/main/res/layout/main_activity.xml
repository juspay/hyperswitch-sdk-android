<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_page"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="48dp"
        android:paddingBottom="32dp">

        <!-- ── Logo / Title ────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:text="@string/app_name"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <!-- ── Server section ──────────────────────────────────────────── -->
        <TextView
            style="@style/HsSectionLabel"
            android:text="@string/section_server" />

        <EditText
            android:id="@+id/ipAddressInput"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginHorizontal="20dp"
            android:autofillHints="url"
            android:background="@drawable/rounded_button_outline"
            android:hint="@string/label_server_url"
            android:inputType="textUri"
            android:paddingHorizontal="16dp"
            android:singleLine="true"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_caption"
            android:textSize="14sp" />

        <Button
            style="@style/HsButtonOutline"
            android:id="@+id/reloadButton"
            android:layout_marginTop="10dp"
            android:text="@string/btn_reload" />

        <!-- ── Divider ──────────────────────────────────────────────────── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="28dp"
            android:background="@color/divider" />

        <!-- ── Payment section ─────────────────────────────────────────── -->
        <TextView
            style="@style/HsSectionLabel"
            android:text="@string/section_payment" />

        <Button
            style="@style/HsButtonPrimary"
            android:id="@+id/launchButton"
            android:enabled="false"
            android:text="@string/btn_launch_payment_sheet" />

        <Button
            style="@style/HsButtonPrimary"
            android:id="@+id/confirmButton"
            android:layout_marginTop="10dp"
            android:enabled="false"
            android:text="@string/btn_confirm_last_used" />

        <!-- ── Status ───────────────────────────────────────────────────── -->
        <TextView
            android:id="@+id/resultText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:minHeight="40dp"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <!-- ── Divider ──────────────────────────────────────────────────── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            android:background="@color/divider" />

        <!-- ── Widget section ──────────────────────────────────────────── -->
        <Button
            style="@style/HsButtonOutline"
            android:id="@+id/launchWidgetLayout"
            android:layout_marginTop="24dp"
            android:text="@string/btn_launch_widget" />

    </LinearLayout>

</ScrollView>

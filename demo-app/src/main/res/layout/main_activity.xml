<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F4F6">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Payment Demo"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp"/>

        <!-- SERVER SECTION -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:elevation="4dp"
            android:layout_marginBottom="16dp"
            android:orientation="vertical">

            <TextView
                android:text="Server"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginBottom="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/ipAddressInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Server IP Address"
                android:padding="12dp"
                android:background="@android:drawable/edit_text"
                android:textSize="16sp"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/reloadButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Reload Client Secret"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:background="@drawable/rounded_button"/>
        </LinearLayout>

        <!-- PAYMENT ACTIONS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:elevation="4dp"
            android:layout_marginBottom="16dp"
            android:orientation="vertical">

            <TextView
                android:text="Payment Actions"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginBottom="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <FrameLayout
                android:id="@+id/widgetContainer"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginBottom="12dp"/>

            <FrameLayout
                android:id="@+id/widgetContainer2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/launchButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Launch Payment Sheet"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:background="@drawable/rounded_button"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/launchWidgetLayout"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Launch Widget Layout"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:background="@drawable/rounded_button"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/confirmButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Confirm with Last Used PM"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:background="@drawable/rounded_button"/>
        </LinearLayout>

        <!-- RESULT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:elevation="4dp"
            android:orientation="vertical">

            <TextView
                android:text="Result"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginBottom="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/resultText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:gravity="center"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>